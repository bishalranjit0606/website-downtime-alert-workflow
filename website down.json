    {
      "parameters": {
        "jsCode": "const item = $input.first().json;\nconst slowThreshold = item.slow_threshold_ms || 3000;\nconst maxRedirects = item.max_redirects || 5;\n\nconst rawUrls = Object.entries(item)\n  .filter(([key]) => key.toLowerCase().startsWith('website'))\n  .map(([key, val]) => ({ key, url: String(val || '').trim() }))\n  .filter(({ url }) => url.length > 0);\n\nconst validUrls = [];\nconst skippedUrls = [];\n\nfor (const { key, url } of rawUrls) {\n  if (/^https?:\\/\\/.+/.test(url)) {\n    validUrls.push(url);\n  } else {\n    skippedUrls.push({ key, url, reason: 'Missing http:// or https://' });\n  }\n}\n\nconst seen = new Set();\nconst uniqueUrls = validUrls.filter(url => {\n  const normalized = url.toLowerCase().replace(/\\/+$/, '');\n  if (seen.has(normalized)) return false;\n  seen.add(normalized);\n  return true;\n});\n\nif (uniqueUrls.length === 0) {\n  throw new Error(\n    'No valid URLs found in Config. Add at least one Website field with a valid http:// or https:// URL. Skipped: ' + JSON.stringify(skippedUrls)\n  );\n}\n\nreturn uniqueUrls.map(url => ({\n  json: {\n    Websites: url,\n    wait_secs: item.wait_secs || 30,\n    alert_email: item.alert_email,\n    slow_threshold_ms: slowThreshold,\n    max_redirects: maxRedirects,\n    skipped_urls: skippedUrls,\n    total_sites_monitored: uniqueUrls.length\n  }\n}));"
      },
