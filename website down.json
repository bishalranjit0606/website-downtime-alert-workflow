    {
      "parameters": {
        "sendTo": "={{ $json.alert_email }}",
        "subject": "=🚨 [{{ $json.status_category }}] Down: {{ $json.website }}",
        "message": "=<!doctype html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n  <title>Website Down Notification</title>\n</head>\n<body style=\"margin:0;padding:0;background:#f2f4f6;font-family:Arial,Helvetica,sans-serif;\">\n  <table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"max-width:600px;margin:24px auto;background:#ffffff;border-radius:6px;overflow:hidden;box-shadow:0 2px 6px rgba(0,0,0,0.08);\">\n    <tr>\n      <td style=\"padding:18px 20px;background:#d63031;color:#ffffff;text-align:center;\">\n        <h1 style=\"margin:0;font-size:20px;\">Website Offline Alert</h1>\n        <p style=\"margin:6px 0 0;font-size:13px;opacity:0.85;\">Two consecutive checks failed — action required</p>\n      </td>\n    </tr>\n    <tr>\n      <td style=\"padding:20px;\">\n        <table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"margin:0 0 16px 0;\">\n          <tr>\n            <td style=\"padding:14px;background:#fff5f5;border:1px solid #ffc9c9;border-radius:6px;font-size:14px;color:#333;line-height:1.8;\">\n              <strong>Website:</strong> {{ $json.website }}<br>\n              <strong>Status code:</strong> {{ $json.status_code === 0 ? '0 - Unreachable (DNS / timeout / network error)' : $json.status_code }}<br>\n              <strong>Category:</strong> {{ $json.status_category }}<br>\n              <strong>Detected at:</strong> {{ $json.checked_at }}<br>\n              <strong>Response time:</strong> {{ $json.response_time_ms > 0 ? $json.response_time_ms + ' ms' : 'N/A (no response)' }}<br>\n              <strong>Confirmation:</strong> Failed 2 of 2 checks\n            </td>\n          </tr>\n        </table>\n        <table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"margin:0 0 16px 0;\">\n          <tr>\n            <td style=\"padding:12px 14px;background:#fffbea;border:1px solid #ffe58f;border-radius:6px;font-size:13px;color:#555;\">\n              <strong>Status category guide:</strong><br>\n              OK — 2xx: normal success<br>\n              REDIRECT — 3xx: redirect loop or misconfiguration<br>\n              CLIENT_ERROR — 4xx: bad request or auth issue<br>\n              SERVER_ERROR — 5xx: server crash or overload<br>\n              NETWORK_ERROR — 0: DNS failure, timeout, or unreachable host\n            </td>\n          </tr>\n        </table>\n        <p style=\"margin:0 0 12px 0;color:#333333;font-size:15px;line-height:1.5;\">Suggested first steps:</p>\n        <ul style=\"margin:0 0 16px 0;padding-left:20px;color:#333;font-size:14px;line-height:1.8;\">\n          <li>Check if your hosting provider is reporting an outage</li>\n          <li>Try opening the URL from a different network or device</li>\n          <li>Review recent deployments or config changes</li>\n          <li>Check server logs and disk/memory usage</li>\n        </ul>\n        <p style=\"margin:0 0 6px 0;color:#777;font-size:13px;\">Alert sent to: <strong>{{ $json.alert_email }}</strong></p>\n      </td>\n    </tr>\n    <tr>\n      <td style=\"padding:12px 20px;background:#fafbfc;color:#99a1ab;font-size:12px;text-align:center;\">Automated uptime monitor — do not reply to this email.</td>\n    </tr>\n  </table>\n</body>\n</html>",
        "options": {}
      },
